<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Luna — 婦科健康知識助理</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@700&display=swap');

  :root {
    --bg: #fff0f5;
    --surface: #fff5f8;
    --surface2: #ffe8f0;
    --border: #f4c6d8;
    --accent: #d63384;
    --accent-soft: #e8779a;
    --accent-light: #ffe0ec;
    --pink-deep: #c2185b;
    --pink-pale: #fce4ec;
    --pink-mid: #f48fb1;
    --text: #2d1b26;
    --text-mid: #6b3a52;
    --text-muted: #b07090;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(180,60,100,0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  .header {
    padding: 14px 22px;
    background: linear-gradient(135deg, #ffe4ef 0%, #ffd6e7 100%);
    border-bottom: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    gap: 13px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-avatar { width: 44px; height: 44px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 3px 12px rgba(214,51,132,0.28); }
  .header-title { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--text); }
  .header-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .header-badge { margin-left: auto; display: flex; align-items: center; gap: 6px; background: white; border: 1px solid var(--border); border-radius: 20px; padding: 5px 12px; font-size: 11px; color: var(--pink-deep); font-weight: 500; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: #e91e8c; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* ── Tabs ── */
  .tabs {
    display: flex;
    background: white;
    border-bottom: 1.5px solid var(--border);
    padding: 0 16px;
    gap: 4px;
    flex-shrink: 0;
  }
  .tab-btn {
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    border-bottom: 2.5px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .tab-btn:hover { color: var(--accent); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

  .tab-panel { display: none; flex: 1; flex-direction: column; }
  .tab-panel.active { display: flex; }

  /* ── CHAT TAB ── */
  #chat-panel { flex: 1; height: calc(100vh - 120px); }
  #messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: linear-gradient(180deg, #fff5f8 0%, #fff0f5 100%);
  }
  #messages::-webkit-scrollbar { width: 4px; }
  #messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .message { display: flex; gap: 9px; max-width: 84%; animation: fadeUp 0.28s ease; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(7px)} to{opacity:1;transform:translateY(0)} }
  .message.user { align-self: flex-end; flex-direction: row-reverse; }
  .message.bot  { align-self: flex-start; }

  .msg-av { width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 4px; font-size: 16px; overflow: hidden; }
  .message.bot .msg-av { box-shadow: 0 2px 8px rgba(214,51,132,0.25); }
  .message.user .msg-av { background: var(--pink-pale); border: 1px solid var(--border); }

  .bubble-wrap { display: flex; flex-direction: column; gap: 3px; }
  .sender { font-size: 10px; color: var(--text-muted); padding: 0 4px; }
  .msg-time { font-size: 9px; color: var(--text-muted); opacity: 0.7; margin-left: 4px; }
  .message.user .sender { text-align: right; }

  .bubble { padding: 11px 15px; font-size: 14px; line-height: 1.78; border-radius: var(--radius); box-shadow: 0 1px 6px rgba(180,60,100,0.07); word-break: break-word; }
  .message.bot .bubble { background: #fff0f6; border: 1px solid #f9c6da; border-top-left-radius: 4px; color: var(--text); }
  .message.user .bubble { background: white; border: 1px solid var(--border); border-top-right-radius: 4px; color: var(--text); white-space: pre-wrap; }

  .typing { display: flex; gap: 5px; padding: 4px 2px; }
  .typing span { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-soft); animation: bounce 1.2s infinite; }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }

  .error-msg { align-self: center; font-size: 12px; color: #c62828; background: #fde8e8; border: 1px solid #ef9a9a; border-radius: 20px; padding: 6px 16px; margin: 10px 0; }

  .input-area { padding: 12px 16px; border-top: 1px solid var(--border); background: var(--surface); display: flex; gap: 10px; align-items: flex-end; flex-shrink: 0; }
  #user-input { flex: 1; background: white; border: 1.5px solid var(--border); border-radius: 16px; color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; padding: 10px 15px; resize: none; outline: none; max-height: 110px; line-height: 1.6; transition: border-color 0.2s; }
  #send-btn { background: linear-gradient(135deg, var(--accent-soft), var(--accent)); border: none; border-radius: 14px; width: 46px; height: 46px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 3px 12px rgba(214,51,132,0.3); }

  .db-badge { font-size: 11px; background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; border-radius: 20px; padding: 4px 10px; display: none; align-items: center; gap: 5px; }
  .db-badge.show { display: flex; }

  /* Bilingual blocks */
  .lang-block { border-radius: 12px; padding: 11px 13px; margin-bottom: 8px; }
  .zh-block { background: #fff5f8; border: 1px solid #f9c6da; }
  .id-block { background: #fff8e1; border: 1px solid #ffe082; }
  .lang-tag { font-size: 11px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; }
  .lang-text { font-size: 13.5px; line-height: 1.8; color: var(--text); white-space: pre-wrap; }

  /* DB & LOG Styles */
  #db-panel, #log-panel { padding: 20px; gap: 16px; overflow-y: auto; }
  .db-upload-zone { border: 2px dashed var(--border); border-radius: var(--radius); padding: 32px; text-align: center; background: white; cursor: pointer; }
  .text-input-box { width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius); padding: 12px 15px; font-size: 13px; outline: none; }
  .btn-pink { background: linear-gradient(135deg, var(--accent-soft), var(--accent)); color: white; border: none; border-radius: 12px; padding: 9px 20px; font-weight: 600; cursor: pointer; }
  .db-list { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }
  .db-item { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 12px 15px; display: flex; align-items: center; gap: 10px; }
  .db-item-del { margin-left: auto; border: none; background: none; cursor: pointer; color: #aaa; }
  .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .stat-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 14px; text-align: center; }
  .stat-num { font-size: 26px; font-weight: 700; color: var(--accent); }
  .log-item { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 13px 15px; margin-bottom: 10px; }
</style>
</head>
<body>

<div class="header">
  <div class="header-avatar">
    <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><circle cx="22" cy="22" r="22" fill="#ffd6e8"/><ellipse cx="22" cy="18" rx="13" ry="14" fill="#4a2040"/><ellipse cx="22" cy="24" rx="11" ry="12" fill="#fde8d0"/><circle cx="18" cy="23" r="2" fill="black"/><circle cx="26" cy="23" r="2" fill="black"/><path d="M18.5 30 Q22 33 25.5 30" stroke="#d6637a" fill="none"/></svg>
  </div>
  <div>
    <div class="header-title">Luna</div>
    <div class="header-sub">婦科健康知識助理 · 中文 & Bahasa Indonesia 🌸</div>
  </div>
  <div class="header-badge"><div class="dot"></div><span>線上中</span></div>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('chat')">💬 聊天</button>
  <button class="tab-btn" onclick="switchTab('db')">🗄️ 資料庫</button>
  <button class="tab-btn" onclick="switchTab('log')">🔬 實驗記錄</button>
</div>

<div id="chat-panel" class="tab-panel active">
  <div id="messages"></div>
  <div class="input-area">
    <div id="db-active-badge" class="db-badge">📂 <span id="db-badge-text">已載入資料庫</span></div>
    <textarea id="user-input" rows="1" placeholder="詢問婦科健康問題 / Tanya Luna...🌸" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
    <button id="send-btn" onclick="sendMessage()"><svg viewBox="0 0 24 24" width="20" fill="white"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg></button>
  </div>
</div>

<div id="db-panel" class="tab-panel">
  <div class="db-upload-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
    <div class="upload-icon">📂</div>
    <p><strong>點擊上傳</strong>或拖放檔案 (CSV/JSON/TXT)</p>
  </div>
  <input type="file" id="file-input" hidden onchange="onFileSelect(event)" />
  <div style="text-align:center; margin:10px 0; font-size:12px; color:#aaa;">── 或輸入文字 ──</div>
  <textarea class="text-input-box" id="text-input" placeholder="貼上資料（例如月經週期、症狀描述等）..." rows="3"></textarea>
  <button class="btn-pink" style="margin-top:8px" onclick="addTextEntry()">＋ 新增到資料庫</button>
  <div class="db-list" id="db-list"></div>
  <button class="btn-pink" style="background:#999; margin-top:20px" onclick="clearAllDb()">🗑 清除所有資料庫內容</button>
</div>

<div id="log-panel" class="tab-panel">
  <div class="stats-row">
    <div class="stat-card"><div class="stat-num" id="stat-total">0</div><div class="stat-label">總問答</div></div>
    <div class="stat-card"><div class="stat-num" id="stat-with-db">0</div><div class="stat-label">有資料庫</div></div>
    <div class="stat-card"><div class="stat-num" id="stat-no-db">0</div><div class="stat-label">無資料庫</div></div>
  </div>
  <div id="log-list" style="margin-top:15px"></div>
  <button class="btn-pink" style="background:#999; margin-top:20px" onclick="clearLog()">🗑 清除所有問答記錄</button>
</div>

<script>
// ════════════════════════════════════════════════════
// STATE & STORAGE
// ════════════════════════════════════════════════════
let isLoading = false;
let chatHistory = [];
let dbEntries = [];
let expLog = [];

// 儲存到 localStorage
function saveData() {
    localStorage.setItem('luna_db', JSON.stringify(dbEntries));
    localStorage.setItem('luna_log', JSON.stringify(expLog));
}

// 從 localStorage 讀取
function loadData() {
    const savedDb = localStorage.getItem('luna_db');
    const savedLog = localStorage.getItem('luna_log');
    if (savedDb) dbEntries = JSON.parse(savedDb);
    if (savedLog) expLog = JSON.parse(savedLog);
    renderDb();
    updateDbBadge();
    updateStats();
    renderLog();
}

const LUNA_SVG = `<svg width="34" height="34" viewBox="0 0 44 44" fill="none"><circle cx="22" cy="22" r="22" fill="#ffd6e8"/><ellipse cx="22" cy="18" rx="13" ry="14" fill="#4a2040"/><ellipse cx="22" cy="24" rx="11" ry="12" fill="#fde8d0"/><circle cx="18" cy="23" r="2" fill="black"/><circle cx="26" cy="23" r="2" fill="black"/><path d="M18.5 30 Q22 33 25.5 30" stroke="#d6637a" fill="none"/></svg>`;

// ════════════════════════════════════════════════════
// UI & NAVIGATION
// ════════════════════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(tab + '-panel').classList.add('active');
  event.currentTarget.classList.add('active');
  if (tab === 'log') renderLog();
}

function escHtml(str) { return (str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>'); }
function scrollToBottom() { const msgs = document.getElementById('messages'); msgs.scrollTop = msgs.scrollHeight; }
function autoResize(el) { el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 110) + 'px'; }
function handleKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }

// ════════════════════════════════════════════════════
// CHAT LOGIC
// ════════════════════════════════════════════════════
function renderBotContent(text) {
  const parts = text.split(/\n---\n|\n---$/);
  if (parts.length >= 2) {
    return `<div class="lang-block zh-block"><div class="lang-tag">🇹🇼 中文</div><div class="lang-text">${escHtml(parts[0].trim())}</div></div>
            <div class="lang-block id-block"><div class="lang-tag">🇮🇩 Indonesia</div><div class="lang-text">${escHtml(parts[1].trim())}</div></div>`;
  }
  return `<div class="lang-text">${escHtml(text)}</div>`;
}

function addMessage(role, text) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'message ' + role;
  const isBot = role === 'bot';
  div.innerHTML = `<div class="msg-av">${isBot ? LUNA_SVG : '👤'}</div><div class="bubble-wrap">
    <div class="sender">${isBot ? 'Luna' : '你'}<span class="msg-time">${new Date().toLocaleTimeString()}</span></div>
    <div class="bubble">${isBot ? renderBotContent(text) : escHtml(text)}</div></div>`;
  msgs.appendChild(div);
  scrollToBottom();
}

async function sendMessage() {
  if (isLoading) return;
  const input = document.getElementById('user-input');
  const prompt = input.value.trim();
  if (!prompt) return;

  input.value = ''; input.style.height = 'auto';
  isLoading = true;
  addMessage('user', prompt);
  
  const tid = 'typing-' + Date.now();
  const msgs = document.getElementById('messages');
  const tdiv = document.createElement('div');
  tdiv.id = tid; tdiv.className = 'message bot';
  tdiv.innerHTML = `<div class="msg-av">${LUNA_SVG}</div><div class="bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
  msgs.appendChild(tdiv); scrollToBottom();

  const dbContext = dbEntries.map(e => `[${e.name}]: ${e.content}`).join('\n');

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, history: chatHistory.slice(-10), dbContext })
    });

    document.getElementById(tid).remove();

    if (!res.ok) throw new Error(`連線失敗 (${res.status})`);

    const data = await res.json();
    const reply = data.reply || "Luna 目前無法回應。";
    addMessage('bot', reply);
    chatHistory.push({ role: 'user', content: prompt }, { role: 'model', content: reply });
    
    // 儲存到紀錄
    expLog.unshift({ time: new Date().toLocaleString(), question: prompt, answer: reply, hasDb: dbEntries.length > 0 });
    updateStats();
    saveData(); // 存檔

  } catch (err) {
    document.getElementById(tid)?.remove();
    const ediv = document.createElement('div'); ediv.className = 'error-msg';
    ediv.innerHTML = `⚠️ 錯誤: ${err.message}`;
    document.getElementById('messages').appendChild(ediv);
    scrollToBottom();
  } finally {
    isLoading = false;
  }
}

// ════════════════════════════════════════════════════
// DATABASE LOGIC
// ════════════════════════════════════════════════════
function onFileSelect(e) { 
    const f = e.target.files[0]; 
    if(!f) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
        dbEntries.push({ id: Date.now(), name: f.name, content: ev.target.result });
        renderDb(); updateDbBadge(); saveData();
    };
    reader.readAsText(f);
}

function addTextEntry() {
    const val = document.getElementById('text-input').value.trim();
    if(val) { 
        dbEntries.push({ id: Date.now(), name: '文字輸入', content: val }); 
        renderDb(); updateDbBadge(); saveData();
        document.getElementById('text-input').value=''; 
    }
}

function deleteDbEntry(id) {
    dbEntries = dbEntries.filter(e => e.id !== id);
    renderDb(); updateDbBadge(); saveData();
}

function renderDb() {
    const list = document.getElementById('db-list');
    list.innerHTML = dbEntries.length === 0 ? '<p style="color:#aaa; font-size:12px; margin-top:10px;">目前無資料</p>' : 
        dbEntries.map((e) => `<div class="db-item">📄 ${e.name} (${e.content.length}字) <button class="db-item-del" onclick="deleteDbEntry(${e.id})">✕</button></div>`).join('');
}

function updateDbBadge() {
    const b = document.getElementById('db-active-badge');
    b.style.display = dbEntries.length > 0 ? 'flex' : 'none';
    document.getElementById('db-badge-text').textContent = `已載入 ${dbEntries.length} 筆資料`;
}

function clearAllDb() {
    if(confirm('確定清除所有資料庫內容？這無法復原。')) {
        dbEntries = []; renderDb(); updateDbBadge(); saveData();
    }
}

// ════════════════════════════════════════════════════
// LOG & STATS LOGIC
// ════════════════════════════════════════════════════
function updateStats() {
    document.getElementById('stat-total').textContent = expLog.length;
    document.getElementById('stat-with-db').textContent = expLog.filter(l=>l.hasDb).length;
    document.getElementById('stat-no-db').textContent = expLog.filter(l=>!l.hasDb).length;
}

function renderLog() {
    const logList = document.getElementById('log-list');
    logList.innerHTML = expLog.length === 0 ? '<p style="color:#aaa; font-size:12px;">尚無問答記錄</p>' :
        expLog.map(l => `<div class="log-item">
        <small style="color:#999">${l.time} [${l.hasDb?'📂 有資料庫':'💬 無資料庫'}]</small>
        <div style="font-weight:bold; margin-top:4px;">Q: ${escHtml(l.question)}</div>
        <div style="font-size:12px; color:#666; margin-top:4px;">A: ${escHtml(l.answer)}</div>
    </div>`).join('');
}

function clearLog() {
    if(confirm('確定清除所有歷史對話記錄？')) {
        expLog = []; updateStats(); renderLog(); saveData();
    }
}

// ════════════════════════════════════════════════════
// INITIALIZATION
// ════════════════════════════════════════════════════
window.onload = () => {
    loadData();
    if (chatHistory.length === 0) {
        addMessage('bot', '嗨！我是 Luna 🌸\n請輸入妳的婦科健康問題，我會同時用中文與印尼文回答。\n---\nHalo! Saya Luna 🌸\nSilakan masukkan pertanyaan Anda, saya akan menjawab dalam bahasa Mandarin dan Indonesia.');
    }
};
</script>
</body>
</html>
